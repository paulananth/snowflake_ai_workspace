{
  "_comment": "Step Functions role — run/monitor ECS tasks and pass the task/execution roles to ECS. iam:PassRole is scoped to exactly the two pipeline roles. Placeholders: ACCOUNT, REGION, CLUSTER, TASK_ROLE_ARN, EXEC_ROLE_ARN substituted by deploy_aws.sh.",
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ECSRunTask",
      "Effect": "Allow",
      "Action": [
        "ecs:RunTask",
        "ecs:DescribeTasks",
        "ecs:StopTask"
      ],
      "Resource": "*",
      "Condition": {
        "ArnLike": {
          "ecs:cluster": "arn:aws:ecs:REGION:ACCOUNT:cluster/CLUSTER"
        }
      }
    },
    {
      "Sid": "PassRoleToECS",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": [
        "arn:aws:iam::ACCOUNT:role/sec-edgar-ecs-task-role",
        "arn:aws:iam::ACCOUNT:role/sec-edgar-ecs-execution-role"
      ]
    }
  ]
}
