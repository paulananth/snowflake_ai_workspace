{
  "_comment": [
    "ADF pipeline definition for the SEC EDGAR Bronze ingest.",
    "4 activities run sequentially: preflight check → tickers → submissions → facts.",
    "",
    "Import via: ADF Studio → Author → Pipelines → ... → Import from JSON.",
    "Or deploy via az CLI:",
    "  az datafactory pipeline create \\",
    "    --factory-name <ADF_NAME> \\",
    "    --resource-group <RESOURCE_GROUP> \\",
    "    --name sec-edgar-bronze-ingest \\",
    "    --pipeline @workflows/adf_pipeline.json",
    "",
    "The 'command' in each Custom Activity runs inside the Docker container",
    "that is configured on the Azure Batch pool (containerConfiguration).",
    "ENV vars (SEC_USER_AGENT, CLOUD_PROVIDER, AZURE_STORAGE_ACCOUNT, etc.)",
    "are set on the Batch pool's environmentSettings — not in this file.",
    "",
    "Timeouts are generous to accommodate full NYSE+Nasdaq runs:",
    "  ValidatePermissions  :  10 minutes",
    "  IngestTickersExchange:  30 minutes",
    "  IngestSubmissions    :   4 hours   (~10k CIKs at 8 req/s with 4 workers)",
    "  IngestCompanyFacts   :   8 hours   (~10k CIKs sequential at 8 req/s)"
  ],
  "name": "sec-edgar-bronze-ingest",
  "properties": {
    "description": "Daily SEC EDGAR Bronze layer: permission check → ticker snapshot → submissions → XBRL facts",
    "parameters": {
      "ingestDate": {
        "type": "string",
        "defaultValue": "2026-04-08",
        "description": "Partition date (YYYY-MM-DD). Set by DailyBronzeIngestTrigger; override for backfill."
      }
    },
    "activities": [
      {
        "name": "ValidatePermissions",
        "description": "Pre-flight: verify ADLS write access and SEC EDGAR reachability before committing to a full run",
        "type": "Custom",
        "dependsOn": [],
        "policy": {
          "timeout": "0.00:10:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "typeProperties": {
          "command": {
            "value": "python scripts/validate_azure_permissions.py --cloud azure",
            "type": "Expression"
          },
          "resourceLinkedService": {
            "referenceName": "AzureStorageLS",
            "type": "LinkedServiceReference"
          },
          "folderPath": "adf-resources"
        },
        "linkedServiceName": {
          "referenceName": "AzureBatchLS",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "IngestTickersExchange",
        "description": "Fetch full SEC ticker-exchange snapshot → bronze/company_tickers_exchange/",
        "type": "Custom",
        "dependsOn": [
          {
            "activity": "ValidatePermissions",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "policy": {
          "timeout": "0.00:30:00",
          "retry": 1,
          "retryIntervalInSeconds": 300,
          "secureOutput": false,
          "secureInput": false
        },
        "typeProperties": {
          "command": {
            "value": "@concat('python scripts/ingest/01_ingest_tickers_exchange.py --date ', pipeline().parameters.ingestDate)",
            "type": "Expression"
          },
          "resourceLinkedService": {
            "referenceName": "AzureStorageLS",
            "type": "LinkedServiceReference"
          },
          "folderPath": "adf-resources"
        },
        "linkedServiceName": {
          "referenceName": "AzureBatchLS",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "IngestSubmissions",
        "description": "Bulk CIK submissions (NYSE+Nasdaq) → bronze/submissions_meta/ + bronze/filings_index/",
        "type": "Custom",
        "dependsOn": [
          {
            "activity": "IngestTickersExchange",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "policy": {
          "timeout": "0.04:00:00",
          "retry": 1,
          "retryIntervalInSeconds": 300,
          "secureOutput": false,
          "secureInput": false
        },
        "typeProperties": {
          "command": {
            "value": "@concat('python scripts/ingest/02_ingest_submissions.py --date ', pipeline().parameters.ingestDate)",
            "type": "Expression"
          },
          "resourceLinkedService": {
            "referenceName": "AzureStorageLS",
            "type": "LinkedServiceReference"
          },
          "folderPath": "adf-resources"
        },
        "linkedServiceName": {
          "referenceName": "AzureBatchLS",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "IngestCompanyFacts",
        "description": "Bulk XBRL facts (all namespaces, all concepts) → bronze/companyfacts/",
        "type": "Custom",
        "dependsOn": [
          {
            "activity": "IngestSubmissions",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "policy": {
          "timeout": "0.08:00:00",
          "retry": 1,
          "retryIntervalInSeconds": 300,
          "secureOutput": false,
          "secureInput": false
        },
        "typeProperties": {
          "command": {
            "value": "@concat('python scripts/ingest/03_ingest_companyfacts.py --date ', pipeline().parameters.ingestDate)",
            "type": "Expression"
          },
          "resourceLinkedService": {
            "referenceName": "AzureStorageLS",
            "type": "LinkedServiceReference"
          },
          "folderPath": "adf-resources"
        },
        "linkedServiceName": {
          "referenceName": "AzureBatchLS",
          "type": "LinkedServiceReference"
        }
      }
    ],
    "annotations": ["sec-edgar", "bronze", "ingest"]
  }
}
