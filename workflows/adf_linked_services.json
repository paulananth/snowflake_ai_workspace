{
  "linkedServices": [
    {
      "name": "AzureStorageLS",
      "type": "Microsoft.DataFactory/factories/linkedservices",
      "properties": {
        "description": "Account-scoped Blob linked service used by ADF Custom Activity staging for sec-edgar/adf-resources. Bronze Parquet I/O happens directly from the Batch host via abfss://...dfs.core.windows.net.",
        "type": "AzureBlobStorage",
        "typeProperties": {
          "accountKind": "StorageV2",
          "connectionString": {
            "type": "SecureString",
            "value": "__SET_BY_DEPLOY__"
          }
        },
        "annotations": ["sec-edgar", "adls"]
      }
    },
    {
      "name": "AzureBatchLS",
      "type": "Microsoft.DataFactory/factories/linkedservices",
      "properties": {
        "description": "Azure Batch host pool that runs the staged SEC EDGAR bundle on the VM host",
        "type": "AzureBatch",
        "typeProperties": {
          "accountName": "mysecedgarbatch",
          "accessKey": {
            "type": "SecureString",
            "value": "__SET_BY_DEPLOY__"
          },
          "batchUri": "https://mysecedgarbatch.eastus.batch.azure.com",
          "poolName": "sec-edgar-pool",
          "linkedServiceName": {
            "referenceName": "AzureStorageLS",
            "type": "LinkedServiceReference"
          }
        },
        "annotations": ["sec-edgar", "batch"]
      }
    }
  ]
}
