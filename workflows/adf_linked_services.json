{
  "_comment": [
    "ADF linked service definitions for the SEC EDGAR Bronze ingest pipeline.",
    "Replace all <PLACEHOLDER> values with your actual resource names before importing.",
    "Import via: ADF Studio → Manage → Linked services → Import, or via az datafactory linked-service create."
  ],
  "linkedServices": [
    {
      "name": "AzureBatchLS",
      "type": "Microsoft.DataFactory/factories/linkedservices",
      "properties": {
        "description": "Azure Batch pool running the sec-edgar-ingest Docker container",
        "type": "AzureBatch",
        "typeProperties": {
          "accountName": "<BATCH_ACCOUNT_NAME>",
          "batchUri": "https://<BATCH_ACCOUNT_NAME>.<AZURE_REGION>.batch.azure.com",
          "poolName": "sec-edgar-pool",
          "linkedServiceName": {
            "referenceName": "AzureStorageLS",
            "type": "LinkedServiceReference"
          },
          "authentication": "ManagedIdentity"
        },
        "connectVia": {
          "referenceName": "AutoResolveIntegrationRuntime",
          "type": "IntegrationRuntimeReference"
        },
        "annotations": ["sec-edgar", "batch"]
      }
    },
    {
      "name": "AzureStorageLS",
      "type": "Microsoft.DataFactory/factories/linkedservices",
      "properties": {
        "description": "ADLS Gen2 storage account — Bronze Parquet output and ADF activity resources",
        "type": "AzureBlobStorage",
        "typeProperties": {
          "serviceEndpoint": "https://<STORAGE_ACCOUNT_NAME>.blob.core.windows.net/",
          "accountKind": "StorageV2",
          "authentication": "ManagedIdentity"
        },
        "connectVia": {
          "referenceName": "AutoResolveIntegrationRuntime",
          "type": "IntegrationRuntimeReference"
        },
        "annotations": ["sec-edgar", "adls"]
      }
    }
  ]
}
